# ============================================================================
# ThoughtTracker — Environment Variables
# Copy this file to .env (root), backend/.env and frontend/.env.local
# ============================================================================

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thoughttracker?schema=public

# ----------------------------------------------------------------------------
# Backend HTTP server
# ----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_ONBOARDING_PIN=
CREATOR_ONBOARDING_PIPELINE_SCRIPT=../thoughttracker-ml/scripts/add_creator_pipeline.mjs
CREATOR_ONBOARDING_API_BASE=http://localhost:4000/api
CREATOR_ONBOARDING_CONCURRENCY=5
CREATOR_ONBOARDING_NO_START_SERVERS=false

# ----------------------------------------------------------------------------
# AI provider abstraction
# AI_PROVIDER: local | openai | anthropic
# AI_API_KEY: only required for hosted providers (openai/anthropic)
# AI_MODEL: provider-specific model id; llama3.1:8b is pulled by
# `npm run setup:local-ai` when AI_PROVIDER=local
# LOCAL_LLM_BASE_URL: Ollama-compatible local LLM base URL
# ----------------------------------------------------------------------------
AI_PROVIDER=local
AI_API_KEY=
AI_MODEL=llama3.1:8b
LOCAL_LLM_BASE_URL=http://localhost:11434

# ----------------------------------------------------------------------------
# Embedding provider abstraction
# EMBEDDING_PROVIDER: ml | openai
# EMBEDDING_MODEL: provider-specific model id
# ----------------------------------------------------------------------------
EMBEDDING_PROVIDER=ml
EMBEDDING_MODEL=text-embedding-3-small

# ----------------------------------------------------------------------------
# YouTube ingestion provider abstraction
# YOUTUBE_PROVIDER: youtube
# Runtime YouTube importing is intentionally disabled until a real importer is configured.
# ----------------------------------------------------------------------------
YOUTUBE_PROVIDER=youtube
YOUTUBE_API_KEY=

# ----------------------------------------------------------------------------
# Optional: companion ML service (thoughttracker-ml)
# The main app uses this service for new stance analysis.
# Allowed STANCE_ANALYSIS_PROVIDER values:
# llm - existing LLM-based stance analysis
# custom_ml - call ML service for stance + confidence
# hybrid - ML provides stance + confidence; LLM provides rationale + quote
# See thoughttracker-ml/integration_contract.md for the request/response shape
# and graceful-degradation rules.
# ----------------------------------------------------------------------------
STANCE_ANALYSIS_PROVIDER=custom_ml
ML_CLASSIFIER_URL=http://localhost:8000
ML_CLASSIFIER_TIMEOUT_MS=4000

# ----------------------------------------------------------------------------
# Topic selection policy
# curated_reranker - trust curated labels by chunk id
# custom_ml_reranker - use the ML topic candidate endpoint directly
# final_policy - apply the frozen calibrated policy over ML candidates
# ----------------------------------------------------------------------------
TOPIC_ASSIGNMENT_PROVIDER=final_policy
TOPIC_SELECTION_POLICY_PATH=../../thoughttracker-ml/models/topic-selection-policy-gold-standard/policy.json
TOPIC_RERANKER_LIMIT=12
TOPIC_RERANKER_MIN_SCORE=0.2
TOPIC_RELEVANCE_PROVIDER=heuristic
TOPIC_RELEVANCE_THRESHOLD=0.8

# ----------------------------------------------------------------------------
# LLM cost controls
# Daily caps stop hosted LLM calls when exceeded. Local Ollama is not metered.
# Per-process counters; roll over every 24h. See ai/llmBudget.ts.
# ----------------------------------------------------------------------------
LLM_DAILY_CALL_CAP=5000
LLM_DAILY_USD_CAP=5.0
LLM_CACHE_ENABLED=true

# ----------------------------------------------------------------------------
# Demo deployment safety
# DEMO_MODE=true enables stricter public-demo rate limits. It does not rewrite
# providers or replace the real corpus.
# ----------------------------------------------------------------------------
DEMO_MODE=false

# ----------------------------------------------------------------------------
# Rate limiting (per IP, applied to API mutations + expensive endpoints)
# ----------------------------------------------------------------------------
API_RATE_LIMIT=120
API_RATE_WINDOW_MS=60000
EXPENSIVE_RATE_LIMIT=10
EXPENSIVE_RATE_WINDOW_MS=60000

# ----------------------------------------------------------------------------
# Request timeout (GET endpoints only; mutations are async and 202 early).
# ----------------------------------------------------------------------------
REQUEST_TIMEOUT_MS=15000

# ----------------------------------------------------------------------------
# Logging
# LOG_LEVEL: trace | debug | info | warn | error
# Defaults to debug in dev, info in prod.
# ----------------------------------------------------------------------------
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# Frontend (Vite)
# ----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000/api
