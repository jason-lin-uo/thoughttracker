# dependencies
node_modules/
.pnp
.pnp.js

# build outputs
dist/
build/
.next/
out/

# environment
.env
.env.local
.env.*.local
!.env.example

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# runtime / coverage
coverage/
.nyc_output/

# editor / OS
.DS_Store
.vscode/*
!.vscode/settings.json
.idea/
*.swp

# prisma
backend/prisma/migrations/dev.db*
backend/prisma/.env

# misc
.tsbuildinfo
*.tsbuildinfo

# database snapshots: *.dump is version-controlled via git-LFS (see .gitattributes)
*.sql.gz
# intermediate dump-bake artifacts — never commit (NOT matched by the *.dump LFS
# filter, so committing one would write a raw multi-hundred-MB blob into git history)
*.dump.new
*.dump.tmp

# e2e + playwright outputs
test-results/
playwright-report/
